NODE_ENV=development
PORT=3000

# Example local database URL:
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/workstudy_hr_lite
DATABASE_URL=postgres://postgres:postgres@localhost:5432/workstudy_hr_lite

# JWT secret used to sign login tokens. Change this in any shared environment.
JWT_SECRET=change-me-in-production-please
JWT_EXPIRES_IN=12h

# AI_PROVIDER can be "mock", "openai", or "gemini".
# "mock" keeps the app usable without paid API keys.
AI_PROVIDER=mock

# OpenAI settings, used when AI_PROVIDER=openai.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Gemini settings, used when AI_PROVIDER=gemini.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
